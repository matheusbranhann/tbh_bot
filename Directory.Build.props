<Project>
  <!-- Propriedades comuns a TODOS os projetos da solução. -->
  <PropertyGroup>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Editor de memória de processo 64-bit: o host TEM que ser x64. -->
    <PlatformTarget>x64</PlatformTarget>
    <Company>matheusbranhann</Company>
    <Product>TbhBot</Product>
    <!-- Versão do release. O AutoUpdate lê daqui (via assembly) pra comparar com o GitHub —
         BUMPAR a cada release, senão o painel publicado nunca se vê como desatualizado. -->
    <Version>4.3.0</Version>
  </PropertyGroup>
</Project>
