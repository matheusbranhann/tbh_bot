<Project Sdk="Microsoft.NET.Sdk">

  <ItemGroup>
    <ProjectReference Include="..\TbhBot.Core\TbhBot.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Assets\runes_icons.json" />
  </ItemGroup>

  <ItemGroup>
    <!-- fontes do novo tema (Outfit + JetBrains Mono) embutidas como Resource -> funcionam no exe single-file -->
    <Resource Include="Assets\Fonts\*.ttf" />
  </ItemGroup>

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- TFM com versão do Windows SDK = habilita as projeções WinRT (Windows.Media.Ocr) p/ o overlay de preço -->
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <SupportedOSPlatformVersion>10.0.17763.0</SupportedOSPlatformVersion>
  </PropertyGroup>

</Project>
